# 複製為 .env 後填入。未設定 FINMIND_TOKEN 時，後端自動以 mock 假資料運行。
FINMIND_TOKEN=
# 資料來源：auto（有 token 用 finmind，否則 mock）/ finmind / mock
DATA_SOURCE=auto

# 排程（每交易日台北時間 18:00 抓取）
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Taipei
SCHEDULER_HOUR=18
SCHEDULER_MINUTE=0

# 警示管道（Phase 3，沿用既有 pipeline；留空則不推播）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
COMPOSITE_ALERT_THRESHOLD=70

# Email（SMTP）警示，留空則不寄送
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# 每週一早上推「本週風險摘要」
WEEKLY_SUMMARY_ENABLED=true
WEEKLY_SUMMARY_HOUR=8
WEEKLY_SUMMARY_MINUTE=0

# 前端 CORS 來源（逗號分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
